<?xml version="1.0" encoding="utf-8"?>
<!-- Brand gradient splash background (purple -> indigo, matching the web
     app's icon/OG image gradient). styles.xml's AppTheme.NoActionBarLaunch
     references @drawable/splash directly; Android resolves this whether
     the file is XML or PNG, so no image-generation tool is needed here. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="#9333EA"
        android:endColor="#4F46E5" />
</shape>
